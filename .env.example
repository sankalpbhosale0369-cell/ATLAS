# =========================================================================
# Google Gemini Chatbot in LangGraph - Environment Variables Template
# =========================================================================

# -------------------------------------------------------------------------
# 1. Core LLM Configuration (REQUIRED)
# -------------------------------------------------------------------------
# Your Google Gemini API Key. Get it from Google AI Studio:
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# -------------------------------------------------------------------------
# 2. Tool Integrations (REQUIRED for stock tool, else OPTIONAL)
# -------------------------------------------------------------------------
# Alpha Vantage API Key for real-time stock price lookup. Get a free key:
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# -------------------------------------------------------------------------
# 3. Model Context Protocol (MCP) Configuration (OPTIONAL)
# -------------------------------------------------------------------------
# Path to the local main.py file of your MCP math server.
# Example (Windows): C:/Users/YourName/Desktop/mcp-math-server/main.py
# Example (macOS/Linux): /Users/yourname/Desktop/mcp-math-server/main.py
MCP_MATH_SERVER_PATH=

# Configurable Python executable to run the MCP math server.
# Defaults to your active virtual environment or system Python if empty.
# Example: python (Windows) or python3 (macOS/Linux)
PYTHON_EXECUTABLE=

# Endpoint URL for the MCP expense server (HTTP / SSE transport).
# Default provided is the public demo server.
MCP_EXPENSE_SERVER_URL=https://splendid-gold-dingo.fastmcp.app/mcp

# -------------------------------------------------------------------------
# 4. LangSmith Tracing & Observability (OPTIONAL)
# -------------------------------------------------------------------------
# Enable/Disable LangSmith tracing (set to "true" to enable).
LANGCHAIN_TRACING_V2=false

# Your LangSmith API Key. Required if tracing is enabled.
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# The name of the project to trace under in LangSmith.
LANGCHAIN_PROJECT=langgraph-gemini-chatbot
